rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isConnectionMember(connectionId) {
      return connectionId is string &&
        connectionId != '' &&
        exists(/databases/$(database)/documents/connections/$(connectionId)) &&
        (isOwner(get(/databases/$(database)/documents/connections/$(connectionId)).data.fromUserId) ||
         isOwner(get(/databases/$(database)/documents/connections/$(connectionId)).data.toUserId));
    }
    function isWishAuthor(data) {
      return (data.authorUid is string && data.authorUid != '' && isOwner(data.authorUid)) ||
        (data.userId is string && isOwner(data.userId));
    }
    function isWishMatched(data) {
      return (data.matchedWithWishId is string && data.matchedWithWishId != '') ||
        data.matchedAt is timestamp;
    }
    function isWishSecretUntilMatched(data) {
      return (data.visibility == 'secret_until_match' || data.visibility == 'secretUntilMatch') &&
        !isWishMatched(data);
    }
    function isLegacyWish(data) {
      return (!(data.connectionId is string)) || data.connectionId == '';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }

    match /connections/{connId} {
      allow read, write: if isSignedIn() &&
        (resource == null || isOwner(resource.data.fromUserId) || isOwner(resource.data.toUserId));
      allow create: if isSignedIn() && isOwner(request.resource.data.fromUserId);
    }

    match /events/{eventId} {
      allow read: if isSignedIn() &&
        (resource == null || isOwner(resource.data.userId) || request.auth.uid == resource.data.partnerId
         || (resource.data.kind == 'wish_today' && resource.data.visibleToPartners == true));
      allow write: if isSignedIn() &&
        (resource == null || isOwner(resource.data.userId) || request.auth.uid == resource.data.partnerId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    match /wishes/{wishId} {
      allow read: if isSignedIn() &&
        (
          isWishAuthor(resource.data) ||
          (isLegacyWish(resource.data) &&
            resource.data.visibleToPartners == true) ||
          (
            !isLegacyWish(resource.data) &&
            isConnectionMember(resource.data.connectionId) &&
            (
              !isWishSecretUntilMatched(resource.data)
            )
          )
        );
      allow create: if isSignedIn() &&
        isWishAuthor(request.resource.data) &&
        isConnectionMember(request.resource.data.connectionId);
      allow update: if isSignedIn() &&
        (
          (
            isLegacyWish(resource.data) &&
            isWishAuthor(resource.data) &&
            request.resource.data.userId == resource.data.userId &&
            request.resource.data.connectionId == resource.data.connectionId &&
            request.resource.data.authorUid == resource.data.authorUid
          ) ||
          (
            !isLegacyWish(resource.data) &&
            (isWishAuthor(resource.data) || isConnectionMember(resource.data.connectionId)) &&
            request.resource.data.userId == resource.data.userId &&
            request.resource.data.connectionId == resource.data.connectionId &&
            request.resource.data.authorUid == resource.data.authorUid &&
            (!isWishSecretUntilMatched(resource.data) || isWishAuthor(resource.data))
          )
        );
      allow delete: if isSignedIn() && isWishAuthor(resource.data);
    }

    match /user_toys/{toyId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    match /game_sessions/{sessionId} {
      allow read: if isSignedIn() &&
        (isOwner(resource.data.userId) ||
         (resource.data.visibleToPartners == true &&
          request.auth.uid in resource.data.participants));
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /advent_days/{dayId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /kink_quiz_results/{resultId} {
      allow read: if isSignedIn() &&
        (isOwner(resource.data.userId) ||
         (resource.data.visibleToPartners == true &&
          request.auth.uid in resource.data.participants));
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /wish_requests/{requestId} {
      allow read: if isSignedIn() &&
        (isOwner(resource.data.fromUserId) || isOwner(resource.data.toUserId));
      allow create: if isSignedIn() && isOwner(request.resource.data.fromUserId);
      allow update: if isSignedIn() && isOwner(resource.data.toUserId);
      allow delete: if false;
    }

    match /user_device_tokens/{tokenId} {
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    match /wish_notifications/{notificationId} {
      allow read: if isSignedIn() &&
        (isOwner(resource.data.fromUserId) || isOwner(resource.data.toUserId));
      allow create: if false;
      allow update: if isSignedIn() && isOwner(resource.data.toUserId);
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if isSignedIn() &&
          (isOwner(get(/databases/$(database)/documents/wish_notifications/$(notificationId)).data.fromUserId) ||
           isOwner(get(/databases/$(database)/documents/wish_notifications/$(notificationId)).data.toUserId));
        allow create: if isSignedIn() &&
          isOwner(request.resource.data.authorUserId) &&
          (isOwner(get(/databases/$(database)/documents/wish_notifications/$(notificationId)).data.fromUserId) ||
           isOwner(get(/databases/$(database)/documents/wish_notifications/$(notificationId)).data.toUserId));
        allow update, delete: if false;
      }
    }
  }
}
